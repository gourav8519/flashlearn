# MongoDB — local or Atlas URI
MONGODB_URI=mongodb://localhost:27017/flashlearn

# NextAuth — generate a production secret with: openssl rand -base64 32
# Also used to derive the AES-256-GCM key that encrypts user-stored Groq API keys.
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional) — leave as "placeholder" to hide the Google sign-in button.
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder

# Groq (optional) — leave as "placeholder" so users must supply their own key in Settings.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=placeholder
